# Ghost — environment variables
# Copy to .env.local and fill in real values. NEVER commit real keys.
# Client-exposed vars must be prefixed NEXT_PUBLIC_.
#
# Core integration tools: You.com, Tavily, Nebius (Token Factory), InsForge.
# Trae is the IDE; Kite AI / Replit are deploy environments (no keys needed here).

# --- You.com (drill / coaching retrieval) ---
YOUDOTCOM_API_KEY=

# --- Tavily (source citation search) ---
TAVILY_API_KEY=

# --- Nebius Token Factory (OpenAI-compatible inference for coaching note) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com

# --- InsForge (auth + persistence) ---
INSFORGE_API_KEY=
INSFORGE_API_BASE_URL=https://api.insforge.com
NEXT_PUBLIC_INSFORGE_URL=
