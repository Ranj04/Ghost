# Ghost — environment variables
# Copy to .env.local and fill in real values. NEVER commit real keys.
# Client-exposed vars must be prefixed NEXT_PUBLIC_.
#
# Product-layer tools: You.com, Tavily, Nebius (coaching gen), InsForge (auth/db), Kite (PvP).
# Submission: FinChip. Dev/host: Trae/Replit + Vercel (no keys needed here).

# --- You.com (flaw-driven drill retrieval) ---
YOUDOTCOM_API_KEY=

# --- Tavily (supporting citation sources) ---
TAVILY_API_KEY=

# --- Nebius Token Factory (OpenAI-compatible inference for coaching note) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# --- InsForge (auth + persistence) ---
INSFORGE_API_KEY=
INSFORGE_API_BASE_URL=https://api.insforge.com
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# --- Kite (PvP form-battle testnet stake; Agent Passport + x402) ---
KITE_RPC_URL=
KITE_FACILITATOR_URL=
KITE_WALLET_KEY=

# --- FinChip (submission: package the coaching skill as an asset) ---
FINCHIP_API_KEY=
